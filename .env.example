# SignSetu — Environment Variables
# Copy to .env and fill in your values.
# Never commit .env to source control.

# ── Database ─────────────────────────────────────────────────────────────────
# MySQL / PlanetScale connection string
DATABASE_URL=mysql://user:password@host:3306/signsetu

# ── Auth ──────────────────────────────────────────────────────────────────────
# Secret used to sign JWT session tokens (min 32 chars, random string)
JWT_SECRET=change-me-to-a-long-random-secret

# OAuth 2.0 / OpenID Connect provider base URL (e.g. Logto, Auth0)
OAUTH_SERVER_URL=https://your-auth-provider.example.com

# OpenID sub claim of the first owner account (bootstraps admin access)
OWNER_OPEN_ID=your-openid-sub-here

# OAuth client application ID registered with the provider
VITE_APP_ID=your-oauth-client-id

# ── AI / Translation ──────────────────────────────────────────────────────────
# Forge (LLM gateway) API base URL
BUILT_IN_FORGE_API_URL=https://forge.example.com

# Forge API key
BUILT_IN_FORGE_API_KEY=forge-api-key-here

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── Analytics (optional) ─────────────────────────────────────────────────────
# Umami self-hosted analytics. Leave blank to disable.
# VITE_ANALYTICS_ENDPOINT=https://your-umami.example.com
# VITE_ANALYTICS_WEBSITE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# ─── LLM provider (Anthropic Haiku) ──────────────────────────────────────────
# Set this to use Anthropic. Default model is claude-haiku-4-5-20251001.
# Leave BUILT_IN_FORGE_API_KEY / OPENAI_API_KEY unset so Anthropic is selected.
ANTHROPIC_API_KEY=sk-ant-...
